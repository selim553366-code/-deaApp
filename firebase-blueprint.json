{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the İdea Ai platform.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "credits": {
          "type": "number",
          "description": "The number of credits the user has available."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has an active premium subscription."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created."
        }
      },
      "required": ["uid", "email", "credits", "isPremium", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A generated website project.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier of the project."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns the project."
        },
        "idea": {
          "type": "string",
          "description": "The original idea prompt."
        },
        "code": {
          "type": "string",
          "description": "The generated HTML/CSS/JS code."
        },
        "title": {
          "type": "string",
          "description": "The title of the project."
        },
        "isPublished": {
          "type": "boolean",
          "description": "Whether the project is published."
        },
        "isPublic": {
          "type": "boolean",
          "description": "Whether the project is public in the gallery."
        },
        "remixOfId": {
          "type": "string",
          "description": "The ID of the project this project is a remix of."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was last updated."
        },
        "chatHistory": {
          "type": "array",
          "description": "The chat history between the user and the AI assistant.",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["user", "model"]
              },
              "text": {
                "type": "string"
              }
            },
            "required": ["role", "text"]
          }
        }
      },
      "required": ["id", "userId", "idea", "code", "createdAt", "updatedAt", "title", "isPublished", "isPublic"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "siteName": {
          "type": "string",
          "description": "The name of the site."
        }
      },
      "required": ["siteName"]
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Settings"
      },
      "description": "Stores global application settings."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and credit balances."
    },
    "/projects/{projectId}": {
      "schema": {
        "$ref": "#/entities/Project"
      },
      "description": "Stores generated website projects."
    }
  }
}
