export default {
  async fetch(request, env) {
    const { prompt } = await request.json();

    const response = await fetch("https://api.openrouter.ai/v1/chat/completions", {
      method: "POST",
      headers: {
        "Authorization": `Bearer ${env.OPENROUTER_KEY}`,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        model: "gpt-4.1-mini",
        messages: [{ role: "user", content: `Create a full HTML website: ${prompt}` }]
      })
    });

    const data = await response.json();
    const html_code = data.choices[0].message.content;

    return new Response(JSON.stringify({ html_code }), { headers: { "Content-Type": "application/json" } });
  }
};
